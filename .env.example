# =============================================
# Docker Compose
# =============================================
MYSQL_ROOT_PASSWORD=change-me-local-root-password

# =============================================
# Spring Boot datasource
# =============================================
DB_URL=jdbc:mysql://localhost:3306/banco_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=change-me-local-db-password

# =============================================
# Kafka
# =============================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# =============================================
# JWT
# =============================================
JWT_SECRET_KEY=change-me-local-jwt-secret-min-32-chars
ISSUER_GENERATOR=banco-service-local

# =============================================
# Jasypt
# =============================================
JASYPT_ENCRYPTOR_PASSWORD=change-me-local-jasypt-password
